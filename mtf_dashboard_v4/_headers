/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# HTML — short cache, must revalidate so updates ship fast
/*.html
  Cache-Control: public, max-age=300, s-maxage=3600, must-revalidate

# Static assets without versioned filenames — short cache
/_redirects
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400

# Daily totals — long-cached because the dashboard appends ?v=<manifest.created>
# as a cache-bust query, so a fresh deploy yields a unique URL anyway.
/*.json
  Cache-Control: public, max-age=86400, s-maxage=604800, immutable
  Content-Type: application/json; charset=utf-8

# Manifest is the version-source for the bust query, so it MUST be fresh on every
# page load. The dashboard appends ?_=Date.now() to bypass cache too — belt + braces.
/compressed_data/manifest.json
  Cache-Control: public, max-age=60, s-maxage=60, must-revalidate
  Content-Type: application/json; charset=utf-8

# CSV exports
/*.csv
  Cache-Control: public, max-age=600, s-maxage=3600
  Content-Type: text/csv; charset=utf-8

# Pre-gzipped chunks — served as raw bytes; the dashboard JS handles decompression
# via DecompressionStream. We deliberately DO NOT set Content-Encoding: gzip,
# otherwise the browser would auto-decompress and JS would try to decompress
# plaintext (boom).
#
# Long cache + immutable is safe here because the dashboard appends
# ?v=<manifest.created> to every chunk URL — each deploy gives every URL a new
# query string, which the CDN treats as a fresh resource. So edge serves cached
# content forever per-version while the data still updates instantly on deploy.
/compressed_data/*.json.gz
  Cache-Control: public, max-age=86400, s-maxage=604800, immutable
  Content-Type: application/octet-stream
