/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# HTML — short cache, must revalidate so updates ship fast
/*.html
  Cache-Control: public, max-age=300, s-maxage=3600, must-revalidate

# Static assets without versioned filenames — short cache
/_redirects
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400

# Daily totals — refresh hourly at the edge, served fast at the browser
/*.json
  Cache-Control: public, max-age=600, s-maxage=3600
  Content-Type: application/json; charset=utf-8

# CSV exports
/*.csv
  Cache-Control: public, max-age=600, s-maxage=3600
  Content-Type: text/csv; charset=utf-8

# Pre-gzipped chunks — served as raw bytes; the dashboard JS handles decompression
# via DecompressionStream. We deliberately DO NOT set Content-Encoding: gzip,
# otherwise the browser would auto-decompress and JS would try to decompress
# plaintext (boom). Long cache because filenames are content-stable.
/compressed_data/*.json.gz
  Cache-Control: public, max-age=86400, s-maxage=604800, immutable
  Content-Type: application/octet-stream
